# ===========================================================================
# Example environment variables.
# Copy this file to ".env" and fill in real values:   cp .env.example .env
# The .env file is git-ignored, so your secrets never get committed.
# ===========================================================================

# The port the server listens on. (Render sets this for you in production.)
PORT=3000

# How to connect to PostgreSQL.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# The default below matches the database started by docker-compose.yml.
DATABASE_URL=postgres://boontweet:boontweet@localhost:5433/boontweet

# A long random string used to sign session cookies. Change this!
# Generate one with:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string
